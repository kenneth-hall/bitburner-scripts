# Bitburner game-save exports Steam drops in the repo dir (not source) --
# root-anchored so it does NOT catch saves/*.json.gz, which Phase 21 commits
# deliberately (the .gz keepers ARE the versioned rollback -- see saves/INDEX.md).
/bitburnerSave_*.json.gz

# saves/: keep the committed .gz keepers, ignore the bulky decompressed/pretty
# forms -- regenerable from the .gz via `node tools/save/sf4grant.mjs describe`
# or a plain gunzip (see saves/INDEX.md header).
saves/*.json
saves/*.pretty.json

